#!/bin/bash
# AI Orchestrator — точка входа (устанавливается в /usr/bin)
set -e

APP_DIR="/usr/share/ai-orchestrator"
VENV_PYTHON="$APP_DIR/venv/bin/python"
CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/ai-orchestrator"
DATA_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/ai-orchestrator"

# Первый запуск — скопировать конфиг
if [ ! -f "$CONFIG_DIR/config.json" ]; then
    mkdir -p "$CONFIG_DIR" "$DATA_DIR"
    if [ -f "$APP_DIR/config.default.json" ]; then
        cp "$APP_DIR/config.default.json" "$CONFIG_DIR/config.json"
    fi
fi

export AI_ORCHESTRATOR_CONFIG="$CONFIG_DIR/config.json"
export AI_ORCHESTRATOR_DATA="$DATA_DIR"

exec "$VENV_PYTHON" -m ai_orchestrator "$@"